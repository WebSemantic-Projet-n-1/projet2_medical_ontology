      "source": [
        "from IPython.display import Markdown, display\n",
        "\n",
        "def _fmt_def(label, text):\n",
        "    if text is None:\n",
        "        return f\"*{label}* : *(absente)*\"\n",
        "    short = text[:200] + \"…\" if len(text) > 200 else text\n",
        "    return f\"*{label}* : {short}\"\n",
        "\n",
        "for c in comparisons:\n",
        "    lines = [f\"### {c['go_id']} — {c['label']}\", \"\"]\n",
        "\n",
        "    # Définition\n",
        "    lines.append(\"**Définition**\")\n",
        "    if not c[\"definition_changed\"]:\n",
        "        lines.append(\"Inchangée entre les deux versions.\")\n",
        "    else:\n",
        "        lines.append(_fmt_def(\"oct. 2025\", c[\"definition_old\"]))\n",
        "        lines.append(\"\")\n",
        "        lines.append(_fmt_def(\"jan. 2026\", c[\"definition_new\"]))\n",
        "    lines.append(\"\")\n",
        "\n",
        "    # Hiérarchie\n",
        "    lines.append(\"**Hiérarchie (parents is_a)**\")\n",
        "    if not c[\"parents_added\"] and not c[\"parents_removed\"]:\n",
        "        lines.append(\"Aucun changement.\")\n",
        "    else:\n",
        "        for p in c[\"parents_added\"]:\n",
        "            lines.append(f\"- + `{p}`\")\n",
        "        for p in c[\"parents_removed\"]:\n",
        "            lines.append(f\"- - `{p}`\")\n",
        "    if c[\"parents_new\"]:\n",
        "        lines.append(f\"Parents actuels (jan. 2026) : {', '.join(f'`{p}`' for p in c['parents_new'])}\")\n",
        "    lines.append(\"\")\n",
        "\n",
        "    # Relations OBO\n",
        "    lines.append(\"**Relations OBO (part_of, regulates…)**\")\n",
        "    if not c[\"relations_added\"] and not c[\"relations_removed\"]:\n",
        "        lines.append(\"Aucun changement.\")\n",
        "    else:\n",
        "        for rel, tgt in c[\"relations_added\"]:\n",
        "            lines.append(f\"- + `{rel}` -> `{tgt}`\")\n",
        "        for rel, tgt in c[\"relations_removed\"]:\n",
        "            lines.append(f\"- - `{rel}` -> `{tgt}`\")\n",
        "    if c[\"relations_new\"]:\n",
        "        lines.append(\"Relations actuelles (jan. 2026) :\")\n",
        "        for rel, targets in sorted(c[\"relations_new\"].items()):\n",
        "            lines.append(f\"  - `{rel}` : {', '.join(f'`{t}`' for t in targets)}\")\n",
        "    lines.append(\"\")\n",
        "    lines.append(\"---\")\n",
        "    lines.append(\"\")\n",
        "\n",
        "    display(Markdown(\"\\n\".join(lines)))"
      ]
    },
