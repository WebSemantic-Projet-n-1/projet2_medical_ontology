      "source": [
        "from typing import Optional, Dict, List, Any\n",
        "from owlready2 import Restriction\n",
        "\n",
        "# ---------------------------------------------------------------------------\n",
        "# Termes analysés\n",
        "# ---------------------------------------------------------------------------\n",
        "TERM_IDS = [\n",
        "    \"GO:0006281\",  # DNA repair (racine)       — http://purl.obolibrary.org/obo/GO_0006281\n",
        "    \"GO:0006284\",  # base-excision repair      — http://purl.obolibrary.org/obo/GO_0006284\n",
        "    \"GO:0006289\",  # nucleotide-excision repair— http://purl.obolibrary.org/obo/GO_0006289\n",
        "    \"GO:0006298\",  # mismatch repair           — http://purl.obolibrary.org/obo/GO_0006298\n",
        "    \"GO:0006302\",  # double-strand break repair— http://purl.obolibrary.org/obo/GO_0006302\n",
        "]\n",
        "\n",
        "# OBO object-property IDs used in GO axioms\n",
        "OBO_RELATION_LABELS = {\n",
        "    # BFO — Basic Formal Ontology \n",
        "    \"BFO_0000050\": \"part_of\",                  # http://purl.obolibrary.org/obo/BFO_0000050\n",
        "    \"BFO_0000051\": \"has_part\",                 # http://purl.obolibrary.org/obo/BFO_0000051\n",
        "    # RO — OBO Relations Ontology\n",
        "    \"RO_0002211\":  \"regulates\",                # http://purl.obolibrary.org/obo/RO_0002211\n",
        "    \"RO_0002212\":  \"negatively_regulates\",     # http://purl.obolibrary.org/obo/RO_0002212\n",
        "    \"RO_0002213\":  \"positively_regulates\",     # http://purl.obolibrary.org/obo/RO_0002213\n",
        "    \"RO_0002264\":  \"acts_upstream_of_or_within\",# http://purl.obolibrary.org/obo/RO_0002264\n",
        "    \"RO_0002295\":  \"results_in_development_of\",# http://purl.obolibrary.org/obo/RO_0002295\n",
        "    \"RO_0002296\":  \"results_in_morphogenesis_of\",# http://purl.obolibrary.org/obo/RO_0002296\n",
        "    \"RO_0002297\":  \"results_in_maturation_of\", # http://purl.obolibrary.org/obo/RO_0002297\n",
        "    \"RO_0001000\":  \"derives_from\",             # http://purl.obolibrary.org/obo/RO_0001000\n",
        "}\n",
        "\n",
        "# ---------------------------------------------------------------------------\n",
        "# Helpers\n",
        "# ---------------------------------------------------------------------------\n",
        "\n",
        "def _go_iri(go_id):\n",
        "    return GO_NS + go_id.replace(\":\", \"_\")\n",
        "\n",
        "def _iri_to_go(iri):\n",
        "    local = iri.rsplit(\"/\", 1)[-1]\n",
        "    return local.replace(\"_\", \":\", 1) if local.startswith(\"GO_\") else local\n",
        "\n",
        "def _get_cls(onto, go_id):\n",
        "    return onto.search_one(iri=_go_iri(go_id))\n",
        "\n",
        "def _get_label(onto, go_id):\n",
        "    cls = _get_cls(onto, go_id)\n",
        "    if cls is None:\n",
        "        return go_id\n",
        "    lbl = getattr(cls, \"label\", None)\n",
        "    if lbl:\n",
        "        return lbl[0] if isinstance(lbl, list) else str(lbl)\n",
        "    return go_id\n",
        "\n",
        "def _get_definition(onto, go_id):\n",
        "    cls = _get_cls(onto, go_id)\n",
        "    if cls is None:\n",
        "        return None\n",
        "    for attr in (\"IAO_0000115\", \"comment\"):\n",
        "        v = getattr(cls, attr, None)\n",
        "        if v:\n",
        "            v = v[0] if isinstance(v, list) else v\n",
        "            if v:\n",
        "                return str(v)\n",
        "    return None\n",
        "\n",
        "def _get_parents(onto, go_id):\n",
        "    cls = _get_cls(onto, go_id)\n",
        "    if cls is None:\n",
        "        return []\n",
        "    return [p.iri for p in cls.is_a if hasattr(p, \"iri\") and p.iri]\n",
        "\n",
        "def _get_relations(onto, go_id):\n",
        "    cls = _get_cls(onto, go_id)\n",
        "    if cls is None:\n",
        "        return {}\n",
        "    relations = {}\n",
        "    for axiom in cls.is_a:\n",
        "        if not isinstance(axiom, Restriction):\n",
        "            continue\n",
        "        local = axiom.property.iri.rsplit(\"/\", 1)[-1] if hasattr(axiom.property, \"iri\") else str(axiom.property)\n",
        "        lbl = OBO_RELATION_LABELS.get(local, local)\n",
        "        target = axiom.value\n",
        "        if target is None or not hasattr(target, \"iri\"):\n",
        "            continue\n",
        "        relations.setdefault(lbl, []).append(_iri_to_go(target.iri))\n",
        "    return relations\n",
        "\n",
        "# ---------------------------------------------------------------------------\n",
        "# Comparaison terme à terme\n",
        "# ---------------------------------------------------------------------------\n",
        "\n",
        "def compare_term(onto_old, onto_new, go_id):\n",
        "    label  = _get_label(onto_new, go_id) or _get_label(onto_old, go_id)\n",
        "    def_old, def_new = _get_definition(onto_old, go_id), _get_definition(onto_new, go_id)\n",
        "    par_old, par_new = set(_get_parents(onto_old, go_id)), set(_get_parents(onto_new, go_id))\n",
        "    rel_old, rel_new = _get_relations(onto_old, go_id), _get_relations(onto_new, go_id)\n",
        "    pairs_old = {(r, t) for r, ts in rel_old.items() for t in ts}\n",
        "    pairs_new = {(r, t) for r, ts in rel_new.items() for t in ts}\n",
        "    return {\n",
        "        \"go_id\":              go_id,\n",
        "        \"label\":              label,\n",
        "        \"definition_changed\": def_old != def_new,\n",
        "        \"definition_old\":     def_old,\n",
        "        \"definition_new\":     def_new,\n",
        "        \"parents_old\":        sorted(_iri_to_go(p) for p in par_old),\n",
        "        \"parents_new\":        sorted(_iri_to_go(p) for p in par_new),\n",
        "        \"parents_added\":      sorted(_iri_to_go(p) for p in (par_new - par_old)),\n",
        "        \"parents_removed\":    sorted(_iri_to_go(p) for p in (par_old - par_new)),\n",
        "        \"relations_old\":      rel_old,\n",
        "        \"relations_new\":      rel_new,\n",
        "        \"relations_added\":    sorted(pairs_new - pairs_old),\n",
        "        \"relations_removed\":  sorted(pairs_old - pairs_new),\n",
        "    }\n",
        "\n",
        "# ---------------------------------------------------------------------------\n",
        "# Résumé tabulaire (une ligne par terme)\n",
        "# ---------------------------------------------------------------------------\n",
        "comparisons = [compare_term(onto_old, onto_new, gid) for gid in TERM_IDS]\n",
        "\n",
        "summary = pd.DataFrame([{\n",
        "    \"go_id\":             c[\"go_id\"],\n",
        "    \"label\":             c[\"label\"],\n",
        "    \"def_changée\":       c[\"definition_changed\"],\n",
        "    \"parents_ajoutés\":   len(c[\"parents_added\"]),\n",
        "    \"parents_retirés\":   len(c[\"parents_removed\"]),\n",
        "    \"rel_ajoutées\":      len(c[\"relations_added\"]),\n",
        "    \"rel_retirées\":      len(c[\"relations_removed\"]),\n",
        "} for c in comparisons]).set_index(\"go_id\")\n",
        "\n",
        "summary"
      ]
    },
