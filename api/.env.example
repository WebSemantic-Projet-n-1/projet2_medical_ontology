# Copier ce fichier en .env et ajuster les valeurs avant docker-compose up.
# Ne jamais commiter le fichier .env dans le dépôt Git.

# ── Apache Jena Fuseki ────────────────────────────────────────────────────────
ADMIN_PASSWORD=admin

# Mémoire JVM allouée à Fuseki (augmenter si les fichiers GO sont très volumineux)
JVM_ARGS=-Xmx2g

# ── Service web / API ─────────────────────────────────────────────────────────
# URL interne Fuseki utilisée par fuseki-loader (entre conteneurs Docker)
FUSEKI_URL=http://fuseki:3030
# Nom du dataset SPARQL Fuseki
FUSEKI_DATASET=ds
# Endpoint SPARQL pour l'API locale (hors Docker) — remplacé par http://fuseki:3030/ds/query dans docker-compose.yml
SPARQL_ENDPOINT=http://localhost:3030/ds/query
