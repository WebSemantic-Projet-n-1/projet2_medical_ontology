{
  "manifest_version": 2,
  "name": "GO Evolution",
  "version": "0.1.0",
  "description": "Affiche l'évolution des termes Gene Ontology (QuickGO, AmiGO, OLS)",
  "permissions": [
    "storage",
    "activeTab",
    "*://www.ebi.ac.uk/QuickGO/*",
    "*://amigo.geneontology.org/*",
    "*://www.ebi.ac.uk/ols/*",
    "*://www.ebi.ac.uk/ols4/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.ebi.ac.uk/QuickGO/term/*",
        "https://amigo.geneontology.org/amigo/term/*",
        "https://www.ebi.ac.uk/ols/ontologies/go/terms/*",
        "https://www.ebi.ac.uk/ols4/ontologies/go/classes/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_icon": "icons/icon-grey.svg",
    "default_popup": "popup/popup.html",
    "default_title": "GO Evolution - Options"
  }
}
